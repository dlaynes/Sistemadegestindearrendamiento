# Frontend environment variables for Vite
# All variables MUST be prefixed with VITE_ to be exposed to the client
# DO NOT commit this file - copy to .env and fill in your values

# Backend API URL
VITE_API_BASE_URL=http://localhost:8080/api

# Supabase configuration (if using Supabase features)
VITE_SUPABASE_URL=https://demo.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Firebase project (for deployment reference)
VITE_FIREBASE_PROJECT=firebase-arrendamiento
